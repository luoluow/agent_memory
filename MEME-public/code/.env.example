# Copy to .env and fill in your keys.
# .env is git-ignored.

# ---- Required ----
# Used by all memory systems for the answering LLM and (where applicable)
# their internal LLM. Not required if you only run dense/BM25 with
# gpt-4.1-mini answering.
OPENAI_API_KEY=

# Used when answering LLM = Claude Sonnet 4 (default for SD experiment).
ANTHROPIC_API_KEY=

# ---- Optional: alternative internal LLMs (Section 4.3 ablation) ----
# OpenRouter is used for GLM-5.1; only needed if you run the GLM internal-LLM
# ablation.
OPENROUTER_API_KEY=

# ---- Optional: Neo4j (Graphiti) ----
# Defaults to bolt://localhost:7687 with neo4j/mempass123. Override only if
# you bring up Neo4j with non-default credentials.
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=mempass123
